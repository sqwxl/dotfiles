{{ if lookPath "fish" }}command = {{ lookPath "fish"}}{{ end }}
shell-integration-features = no-cursor

scrollback-limit = 1000000000
scrollbar = never

theme = Gruvbox Dark
{{ if eq .chezmoi.os "darwin" -}}
window-colorspace = display-p3
alpha-blending = native
{{- else -}}
gtk-titlebar = true
gtk-titlebar-style = tabs
{{- end }}

window-height = 60
window-width = 100

font-family = Jetbrains Mono
font-family = Symbols Nerd Font
font-size = 13
font-feature = -calt, -liga, -dlig # disable ligatures

unfocused-split-opacity=0.8

desktop-notifications = false

window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

quit-after-last-window-closed = true

macos-option-as-alt = true

{{ if eq .chezmoi.os "darwin" -}}
keybind = shift+enter=text:\n
{{- end }}
keybind = shift+page_up=scroll_page_fractional:-0.5
keybind = shift+page_down=scroll_page_fractional:0.5
# c-tab is bound at the OS level for now...
# keybind = unconsumed:ctrl+tab=unbind
# keybind = unconsumed:ctrl+shift+tab=unbind
keybind = shift+alt+c=goto_split:up
keybind = shift+alt+t=goto_split:down
keybind = shift+alt+h=goto_split:left
keybind = shift+alt+n=goto_split:right

mouse-hide-while-typing = true
copy-on-select = clipboard

